{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StaticFiles": {
    "Enabled": true,
    "RequestPathPrefix": "/static",
    "RootDirectory": "wwwroot/static",
    "EnableCaching": true,
    "CacheSeconds": 86400,
    "AddETag": true,
    "AddLastModified": true,
    "AllowUnknownMime": false,
    "DefaultMimeType": "application/octet-stream"
  }
}
